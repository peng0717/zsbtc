# ========== 数据库（Turso）==========
# Turso 数据库连接地址（libsql:// 或 https:// 格式）
TURSO_URL=libsql://your-database-name.turso.io
# Turso 认证 Token（在 Turso 控制台获取）
TURSO_TOKEN=your-turso-token-here

# ========== JWT ==========
# JWT 签名密钥（请修改为随机长字符串，用于 token 签发/验证）
JWT_SECRET=your-jwt-secret-here-change-this

# ========== 服务端口 ==========
# 本地开发启动端口，默认 3001（server.js 中默认 3001，非 3000）
PORT=3001

# ========== 初始管理员（可选）==========
# 首次启动自动创建的管理员账号，两者均配置时才生效
ADMIN_SEED_STUDENT_ID=admin
ADMIN_SEED_PASSWORD=your-admin-password-here

# ========== CORS 跨域（可选）==========
# 允许的前端域名列表，逗号分隔，未配置则默认允许 http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ========== 日志级别（可选）==========
# pino 日志级别：trace / debug / info / warn / error / fatal
LOG_LEVEL=info

# ========== Vercel 部署（可选）==========
# 部署到 Vercel 时自动注入，本地开发无需设置
# VERCEL=1
# NODE_ENV=production
